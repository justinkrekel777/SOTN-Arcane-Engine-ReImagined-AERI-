------------------------------------------------------------
-- "DEBUG MODE OPTIONS"
------------------------------------------------------------
"Enables console logging, dumps, and on screen displays"

"Dumps parsed config data into console"
CONFIG_DUMP: "false"

"Logs detected inputs each frame when not in a menu, map, or screen transition"
"This option causes SEVERE lag and is best used in frame by frame mode"
INPUT_READER_TEST: "false"

"Displays ram reads in real time"
RAM_READ_OSD: "false"

"Displays important numeric variable data in real time"
VARIABLE_WATCH_OSD: "false"

"Displays important boolean logic in real time"
LOGIC_WATCH_OSD: "false"



------------------------------------------------------------
-- "INPUT SYSTEM REFERENCE IDs - DO NOT EDIT THIS SECTION OR THINGS WILL BREAK!!!"
------------------------------------------------------------
"Internal reference ID library for use within the input parsing and execution systems"
"Allows the script to indirectly 'see' custom bindings from Bizhawk's controller config menu and pass it to the program"
"These binds should mimic BizHawk's PSX control names in defctrl.json or joypad.get(), do not including port# prefixes"
"Inputs are read and executed via 'Virtual Port 1 - DualShock' and will not work with other virtual controller ports"

"------DO NOT EDIT------"

D-Pad Up: "D-Pad Up"
D-Pad Down: "D-Pad Down"
D-Pad Left: "D-Pad Left"
D-Pad Right: "D-Pad Right"

Triangle: "△"
Cross: "X"
Square: "□"
Circle: "○"

L1: "L1"
L2: "L2"
R1: "R1"
R2: "R2"

"------DO NOT EDIT------"

